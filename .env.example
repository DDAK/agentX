# AgentX environment configuration
# Copy to `.env` and fill in your keys. Never commit `.env`.

# ── LLM provider keys ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here
GEMINI_API_KEY=your-key-here

# ── LiteLLM gateway ───────────────────────────────────────────────────────────
# This key is set in litellm_config.yaml and must match LITELLM_API_KEY below.
LITELLM_MASTER_KEY=sk-agentx-dev

# ── Agent / server ────────────────────────────────────────────────────────────
# "serve" = HTTP API (default, used by docker-compose)
# "cli"   = interactive terminal REPL  (cargo run -- --cli)
AGENTX_MODE=serve
BIND_ADDR=0.0.0.0:8080

# ── LiteLLM client (used by the agent, e.g. CLI on the host) ─────────────────
LITELLM_BASE_URL=http://localhost:4000
LITELLM_API_KEY=sk-agentx-dev       # must match LITELLM_MASTER_KEY above
AGENT_MODEL=claude-3-7-sonnet-20250219
AGENT_MAX_TOKENS=8192
AGENT_TEMPERATURE=0.0

# ── Container gateway (docker-compose only) ──────────────────────────────────
# The agent container attaches to an external network hosting a shared LiteLLM
# gateway. Set these to your deployment's real network/service names; the
# committed defaults are generic placeholders.
LLM_NETWORK=atom_network
LITELLM_GW_URL=http://atom-litellm:4000
LITELLM_GW_KEY=sk-atom-litellm
LITELLM_GW_MODEL=claude-haiku-4-5-20251001

# ── MCP (Model Context Protocol) tool servers ────────────────────────────────
# Optional. Path to a .mcp.json listing stdio MCP servers to spawn at startup.
# Defaults to ./.mcp.json; if the file is absent, no MCP servers are started.
# MCP_CONFIG=.mcp.json

# ── Storage ───────────────────────────────────────────────────────────────────
# "filesystem" — no extra services, sessions stored in .agentx/sessions/
# "postgres"   — requires DATABASE_URL; used in docker-compose by default
STORAGE_BACKEND=filesystem
WORKSPACE_DIR=./workspace

# Postgres (only required when STORAGE_BACKEND=postgres)
POSTGRES_PASSWORD=agentx_dev
DATABASE_URL=postgres://agentx:agentx_dev@localhost:5432/agentx

# ── CLI mode options (only apply when AGENTX_MODE=cli) ───────────────────────
SESSION_LABEL=
RESUME_SESSION=         # set to a UUID to resume a previous session
CONFIRM_COMMANDS=false  # true = require y/N before run_command

# ── Dynamic extensions ───────────────────────────────────────────────────────
# Directory holding config.yaml, skills/*.md, and commands/*.rhai. Loaded at
# startup; edit and restart to change agent behaviour without recompiling.
# AGENTX_HOME=agentx.d

# ── Logging ───────────────────────────────────────────────────────────────────
# Examples: "agentx=debug", "agentx=trace,warn", "info"
RUST_LOG=agentx=info,warn
